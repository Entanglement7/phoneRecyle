<template>
  <view class="container">
    <view class="header">
      <text class="title">华为机型信息管理</text>
    </view>
    <button type="primary" class="add-btn" @click="showAddModel">添加机型</button>
    <view class="list-section">
      <view class="list-item" v-for="(model, index) in models" :key="index">
        <view class="item-header">
          <text class="item-name">{{ model.name }}</text>
          <view class="item-actions">
            <button type="default" class="action-btn" @click="editModel(index)">编辑</button>
            <button type="default" class="action-btn delete" @click="deleteModel(index)">删除</button>
          </view>
        </view>
        <view class="item-body">
          <view class="item-detail">
            <text class="detail-label">型号：</text>
            <text class="detail-value">{{ model.model }}</text>
          </view>
          <view class="item-detail">
            <text class="detail-label">上市价格：</text>
            <text class="detail-value">¥{{ model.price }}</text>
          </view>
          <view class="item-detail">
            <text class="detail-label">基础配置：</text>
            <text class="detail-value">{{ model.config }}</text>
          </view>
        </view>
      </view>
      <view class="empty" v-if="models.length === 0">
        <text>暂无机型信息</text>
      </view>
    </view>
    <!-- 添加/编辑机型弹窗 -->
    <view class="modal" v-if="showModal">
      <view class="modal-content">
        <view class="modal-header">
          <text class="modal-title">{{ isEditing ? '编辑机型' : '添加机型' }}</text>
          <text class="modal-close" @click="showModal = false">×</text>
        </view>
        <form class="modal-form">
          <view class="form-item">
            <text class="label">机型名称</text>
            <input type="text" v-model="formData.name" placeholder="请输入机型名称" class="input" />
          </view>
          <view class="form-item">
            <text class="label">型号</text>
            <input type="text" v-model="formData.model" placeholder="请输入型号" class="input" />
          </view>
          <view class="form-item">
            <text class="label">上市价格</text>
            <input type="number" v-model="formData.price" placeholder="请输入上市价格" class="input" />
          </view>
          <view class="form-item">
            <text class="label">基础配置</text>
            <input type="text" v-model="formData.config" placeholder="请输入基础配置" class="input" />
          </view>
          <view class="modal-actions">
            <button type="default" class="modal-btn" @click="showModal = false">取消</button>
            <button type="primary" class="modal-btn" @click="saveModel">保存</button>
          </view>
        </form>
      </view>
    </view>
  </view>
</template>

<script setup>
import { ref, onMounted } from 'vue';

const models = ref([]);
const showModal = ref(false);
const isEditing = ref(false);
const editingIndex = ref(-1);
const formData = ref({
  name: '',
  model: '',
  price: '',
  config: ''
});

onMounted(() => {
  // 从本地存储获取机型数据
  const savedModels = uni.getStorageSync('phoneModels');
  if (savedModels) {
    models.value = savedModels;
  } else {
    // 初始化默认数据
    models.value = [
      {
        name: '华为 Mate 60 Pro',
        model: 'Mate 60 Pro',
        price: '6999',
        config: '8GB+256GB, 麒麟9000S, 6.8英寸'
      },
      {
        name: '华为 P60 Pro',
        model: 'P60 Pro',
        price: '6988',
        config: '8GB+256GB, 骁龙8+ Gen 1, 6.67英寸'
      }
    ];
    uni.setStorageSync('phoneModels', models.value);
  }
});

const showAddModel = () => {
  isEditing.value = false;
  editingIndex.value = -1;
  formData.value = {
    name: '',
    model: '',
    price: '',
    config: ''
  };
  showModal.value = true;
};

const editModel = (index) => {
  isEditing.value = true;
  editingIndex.value = index;
  formData.value = { ...models.value[index] };
  showModal.value = true;
};

const deleteModel = (index) => {
  uni.showModal({
    title: '确认删除',
    content: '确定要删除这个机型吗？',
    success: (res) => {
      if (res.confirm) {
        models.value.splice(index, 1);
        uni.setStorageSync('phoneModels', models.value);
        uni.showToast({ title: '删除成功', icon: 'success' });
      }
    }
  });
};

const saveModel = () => {
  if (!formData.value.name || !formData.value.model || !formData.value.price || !formData.value.config) {
    uni.showToast({ title: '请填写完整信息', icon: 'none' });
    return;
  }
  
  if (isEditing.value) {
    models.value[editingIndex.value] = { ...formData.value };
  } else {
    models.value.push({ ...formData.value });
  }
  
  uni.setStorageSync('phoneModels', models.value);
  showModal.value = false;
  uni.showToast({ title: '保存成功', icon: 'success' });
};
</script>

