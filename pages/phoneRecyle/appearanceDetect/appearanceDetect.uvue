<template>
  <view class="container">
    <view class="page-header">
      <text class="page-title">手机外观检测</text>
      <text class="page-desc">上传手机图片，AI 自动评估外观状态</text>
    </view>
    <view class="card upload-section">
      <text class="section-title">上传手机外观图片</text>
      <text class="section-hint">最多上传 4 张，建议拍摄正面、背面、边框</text>
      <view class="upload-grid">
        <view class="upload-item" v-for="(item, index) in imageList" :key="index">
          <image :src="item" class="uploaded-image" mode="aspectFill" />
          <view class="delete-btn" @click="deleteImage(index)">×</view>
        </view>
        <view class="upload-item upload-btn" @click="chooseImage" v-if="imageList.length < 4">
          <text class="upload-icon">+</text>
          <text class="upload-text">添加图片</text>
        </view>
      </view>
    </view>
    <button type="primary" class="detect-btn" @click="detectAppearance" :disabled="imageList.length === 0">
      开始 AI 检测
    </button>
    <view class="card result-section" v-if="appearanceScore > 0">
      <text class="section-title">检测结果</text>
      <view class="score-card">
        <view class="score-info">
          <text class="score-label">外观综合评分</text>
          <view class="score-row">
            <text class="score-value">{{ appearanceScore }}</text>
            <text class="score-unit">/ 100</text>
          </view>
        </view>
        <view class="score-bar-wrap">
          <view class="score-bar" :style="{ width: appearanceScore + '%' }" />
        </view>
      </view>
      <view class="detail-list">
        <view class="detail-row">
          <text class="detail-label">屏幕状态</text>
          <text class="detail-value good">{{ screenCondition }}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">机身状态</text>
          <text class="detail-value warn">{{ bodyCondition }}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">边框状态</text>
          <text class="detail-value good">{{ borderCondition }}</text>
        </view>
      </view>
      <button type="primary" class="next-btn" @click="nextStep">下一步：功能检测</button>
    </view>
  </view>
</template>

<script setup>
import { ref } from 'vue';

const imageList = ref([]);
const appearanceScore = ref(0);
const screenCondition = ref('');
const bodyCondition = ref('');
const borderCondition = ref('');

const chooseImage = () => {
  uni.chooseImage({
    count: 4 - imageList.value.length,
    sizeType: ['compressed'],
    success: (res) => {
      imageList.value = [...imageList.value, ...res.tempFilePaths];
    }
  });
};

const deleteImage = (index) => {
  imageList.value.splice(index, 1);
};

const detectAppearance = () => {
  uni.showLoading({ title: '检测中...' });
  setTimeout(() => {
    uni.hideLoading();
    appearanceScore.value = Math.floor(Math.random() * 20) + 80;
    screenCondition.value = '良好';
    bodyCondition.value = '轻微划痕';
    borderCondition.value = '正常';
    uni.setStorageSync('appearanceScore', appearanceScore.value);
    uni.showToast({ title: '检测完成', icon: 'success' });
  }, 2000);
};

const nextStep = () => {
  uni.navigateTo({ url: '/pages/phoneRecyle/functionTest/functionTest' });
};
</script>

<style scoped>
