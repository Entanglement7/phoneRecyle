  width: 44rpx;
  height: 44rpx;
  background-color: rgba(0, 0, 0, 0.55);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
}

.upload-btn {
  background-color: #f8fafc;
}

.upload-icon {
  font-size: 64rpx;
  color: #a855f7;
  margin-bottom: 8rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #94a3b8;
}

