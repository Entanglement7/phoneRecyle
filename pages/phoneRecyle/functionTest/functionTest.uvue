  background-color: #fff;
  margin: 24rpx 24rpx 0;
  padding: 28rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.07);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1e293b;
  margin-bottom: 24rpx;
  display: block;
}

.input-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #f8fafc;
  border: 1rpx solid #e2e8f0;
  border-radius: 14rpx;
  padding: 0 24rpx;
  height: 88rpx;
}

.input-inner {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.input {
  flex: 1;
  height: 88rpx;
  font-size: 28rpx;
  color: #1e293b;
  background-color: transparent;
}

.input-suffix {
  font-size: 28rpx;
  color: #94a3b8;
  margin-left: 8rpx;
}

.func-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.func-row:last-child {
  border-bottom: none;
}

.func-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #334155;
}

.radio-group {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.radio-item {
  padding: 12rpx 32rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 12rpx;
  background-color: #f8fafc;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
}

.radio-item.active {
  border-color: #10b981;
  background-color: #ecfdf5;
}

.radio-item.radio-bad.active-bad {
  border-color: #f43f5e;
  background-color: #fff1f2;
}

.radio-text {
  font-size: 26rpx;
  color: #64748b;
}

.radio-item.active .radio-text {
  color: #059669;
  font-weight: 600;
}

.radio-item.radio-bad.active-bad .radio-text {
  color: #f43f5e;
  font-weight: 600;
}

.divider {
  height: 1rpx;
  background-color: #f1f5f9;
}

.repair-detail {
  padding-top: 20rpx;
}

.input-box {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #f8fafc;
  border: 1rpx solid #e2e8f0;
  border-radius: 14rpx;
  padding: 0 24rpx;
  margin-top: 12rpx;
}

.submit-btn {
  margin: 32rpx 24rpx 48rpx;
  padding: 28rpx;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 16rpx;
  background-color: #1a56db;
  border: none;
}
</style>
