<template>
  <scroll-view scroll-y class="container">
    <view class="page-header">
      <text class="page-title">硬件功能检测</text>
      <text class="page-desc">请如实填写手机各项功能的状态</text>
    </view>

    <!-- 电池健康度 -->
    <view class="card">
      <text class="section-title">电池健康度</text>
      <view class="input-wrap">
        <view class="input-inner">
          <input
            type="number"
            v-model="batteryHealth"
            placeholder="请输入百分比，如 95"
            placeholder-style="color:#94a3b8;font-size:28rpx;"
            class="input"
          />
        </view>
        <text class="input-suffix">%</text>
      </view>
    </view>

    <!-- 硬件功能 -->
    <view class="card">
      <text class="section-title">硬件功能检测</text>

      <view v-for="item in funcItems" :key="item.key" class="func-row">
        <text class="func-label">{{ item.label }}</text>
        <view class="radio-group">
          <view class="radio-item" :class="{ active: funcForm[item.key] === '正常' }" @click="funcForm[item.key] = '正常'">
            <text class="radio-text">正常</text>
          </view>
          <view class="radio-item radio-bad" :class="{ 'active-bad': funcForm[item.key] === '异常' }" @click="funcForm[item.key] = '异常'">
            <text class="radio-text">异常</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 维修进水查验 -->
    <view class="card">
      <text class="section-title">维修进水查验</text>

      <view class="func-row">
        <text class="func-label">进水痕迹</text>
        <view class="radio-group">
          <view class="radio-item" :class="{ active: waterDamage === '无' }" @click="waterDamage = '无'">
            <text class="radio-text">无</text>
          </view>
          <view class="radio-item radio-bad" :class="{ 'active-bad': waterDamage === '有' }" @click="waterDamage = '有'">
            <text class="radio-text">有</text>
          </view>
        </view>
      </view>

      <view class="divider" />

      <view class="func-row">
        <text class="func-label">曾经维修</text>
        <view class="radio-group">
          <view class="radio-item" :class="{ active: repaired === '未维修' }" @click="repaired = '未维修'">
            <text class="radio-text">未维修</text>
          </view>
          <view class="radio-item radio-bad" :class="{ 'active-bad': repaired === '已维修' }" @click="repaired = '已维修'">
            <text class="radio-text">已维修</text>
          </view>
        </view>
      </view>

      <view v-if="repaired === '已维修'" class="repair-detail">
        <text class="func-label">维修说明</text>
        <view class="input-box">
          <input v-model="repairNote" placeholder="请简述维修内容，如：换屏、换电池" class="input" />
        </view>
      </view>
    </view>

    <button type="primary" class="submit-btn" @click="submitFunctionTest">提交并查看估值结果</button>
  </scroll-view>
</template>

<script setup>
import { ref, reactive } from 'vue';

const batteryHealth = ref('');

const funcItems = [
  { key: 'camera',       label: '摄像头' },
  { key: 'microphone',   label: '麦克风' },
  { key: 'fingerprint',  label: '指纹识别' },
  { key: 'chargingPort', label: '充电口' },
  { key: 'screen',       label: '屏幕触控' },
  { key: 'speaker',      label: '扬声器' },
  { key: 'volumeKey',    label: '音量键' },
  { key: 'powerKey',     label: '电源键' },
];

const funcForm = reactive({
  camera: '正常', microphone: '正常', fingerprint: '正常',
  chargingPort: '正常', screen: '正常', speaker: '正常',
  volumeKey: '正常', powerKey: '正常',
});

const waterDamage = ref('无');
const repaired    = ref('未维修');
const repairNote  = ref('');

const submitFunctionTest = () => {
  if (!batteryHealth.value) {
    uni.showToast({ title: '请输入电池健康度', icon: 'none' });
    return;
  }
  uni.setStorageSync('functionStatus', {
    batteryHealth: batteryHealth.value,
    ...funcForm,
    waterDamage: waterDamage.value,
    repaired: repaired.value,
    repairNote: repairNote.value,
  });
  uni.navigateTo({ url: '/pages/phoneRecyle/valuationResult/valuationResult' });
};
</script>

<style scoped>
