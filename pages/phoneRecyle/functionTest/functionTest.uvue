  display: block;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #334155;
}

.input-wrap {
  display: flex;
  align-items: center;
  background-color: #f8fafc;
  border: 1rpx solid #e2e8f0;
  border-radius: 14rpx;
  padding: 0 24rpx;
}

.input {
  flex: 1;
  padding: 22rpx 0;
  font-size: 28rpx;
  color: #1e293b;
}

.input-suffix {
  font-size: 28rpx;
  color: #94a3b8;
  margin-left: 8rpx;
}

.radio-group {
  display: flex;
  gap: 20rpx;
}

.radio-item {
  flex: 1;
  padding: 18rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f8fafc;
}

.radio-item.active {
  border-color: #10b981;
  background-color: #ecfdf5;
}

.radio-item.radio-item-bad.active-bad {
  border-color: #f43f5e;
  background-color: #fff1f2;
}

.radio-text {
  font-size: 28rpx;
  color: #64748b;
  font-weight: 500;
}

.radio-item.active .radio-text {
  color: #059669;
  font-weight: 600;
}

.radio-item.radio-item-bad.active-bad .radio-text {
  color: #f43f5e;
  font-weight: 600;
}

.submit-btn {
  width: 100%;
  margin: 30rpx 0 36rpx;
  padding: 28rpx;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 16rpx;
  background-color: #1a56db;
  border: none;
}
