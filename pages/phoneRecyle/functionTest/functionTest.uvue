<template>
  <view class="container">
    <view class="page-header">
      <text class="page-title">功能状态检测</text>
      <text class="page-desc">请如实填写手机各项功能的状态</text>
    </view>
    <view class="card form">
      <view class="form-item">
        <text class="label">电池健康度</text>
        <view class="input-wrap">
          <input type="number" v-model="batteryHealth" placeholder="请输入百分比，如 95" class="input" />
          <text class="input-suffix">%</text>
        </view>
      </view>
      <view class="divider" />
      <view class="form-item">
        <text class="label">摄像头</text>
        <view class="radio-group">
          <view class="radio-item" :class="{ active: camera === '正常' }" @click="camera = '正常'">
            <text class="radio-text">正常</text>
          </view>
          <view class="radio-item radio-item-bad" :class="{ 'active-bad': camera === '异常' }" @click="camera = '异常'">
            <text class="radio-text">异常</text>
          </view>
        </view>
      </view>
      <view class="divider" />
      <view class="form-item">
        <text class="label">指纹识别</text>
        <view class="radio-group">
          <view class="radio-item" :class="{ active: fingerprint === '正常' }" @click="fingerprint = '正常'">
            <text class="radio-text">正常</text>
          </view>
          <view class="radio-item radio-item-bad" :class="{ 'active-bad': fingerprint === '异常' }" @click="fingerprint = '异常'">
            <text class="radio-text">异常</text>
          </view>
        </view>
      </view>
      <view class="divider" />
      <view class="form-item">
        <text class="label">充电口</text>
        <view class="radio-group">
          <view class="radio-item" :class="{ active: chargingPort === '正常' }" @click="chargingPort = '正常'">
            <text class="radio-text">正常</text>
          </view>
          <view class="radio-item radio-item-bad" :class="{ 'active-bad': chargingPort === '异常' }" @click="chargingPort = '异常'">
            <text class="radio-text">异常</text>
          </view>
        </view>
      </view>
      <view class="divider" />
      <view class="form-item">
        <text class="label">屏幕</text>
        <view class="radio-group">
          <view class="radio-item" :class="{ active: screen === '正常' }" @click="screen = '正常'">
            <text class="radio-text">正常</text>
          </view>
          <view class="radio-item radio-item-bad" :class="{ 'active-bad': screen === '异常' }" @click="screen = '异常'">
            <text class="radio-text">异常</text>
          </view>
        </view>
      </view>
      <view class="divider" />
      <view class="form-item">
        <text class="label">扬声器</text>
        <view class="radio-group">
          <view class="radio-item" :class="{ active: speaker === '正常' }" @click="speaker = '正常'">
            <text class="radio-text">正常</text>
          </view>
          <view class="radio-item radio-item-bad" :class="{ 'active-bad': speaker === '异常' }" @click="speaker = '异常'">
            <text class="radio-text">异常</text>
          </view>
        </view>
      </view>
      <button type="primary" class="submit-btn" @click="submitFunctionTest">提交并查看估值结果</button>
    </view>
  </view>
</template>

<script setup>
import { ref } from 'vue';

const batteryHealth = ref('');
const camera = ref('正常');
const fingerprint = ref('正常');
const chargingPort = ref('正常');
const screen = ref('正常');
const speaker = ref('正常');

const submitFunctionTest = () => {
  if (!batteryHealth.value) {
    uni.showToast({ title: '请输入电池健康度', icon: 'none' });
    return;
  }

  const functionStatus = {
    batteryHealth: batteryHealth.value,
    camera: camera.value,
    fingerprint: fingerprint.value,
    chargingPort: chargingPort.value,
    screen: screen.value,
    speaker: speaker.value
  };

  uni.setStorageSync('functionStatus', functionStatus);
  uni.showToast({ title: '检测结果提交成功', icon: 'success' });
  setTimeout(() => {
    uni.navigateTo({ url: '/pages/phoneRecyle/valuationResult/valuationResult' });
  }, 1000);
};
</script>

<style scoped>
