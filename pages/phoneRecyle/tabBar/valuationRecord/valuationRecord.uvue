  background-color: #f5f6fa;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.page-header {
  background-color: #1a56db;
  padding: 40rpx 30rpx 30rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.search-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin: 20rpx 24rpx;
  gap: 16rpx;
}

.search-input {
  flex: 1;
  background-color: #fff;
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 26rpx;
  color: #1e293b;
}

.search-btn {
  background-color: #1a56db;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 18rpx 30rpx;
  font-size: 26rpx;
  white-space: nowrap;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 28rpx; color: #94a3b8; }

/* 卡片 */
.record-card {
  background-color: #fff;
  margin: 0 24rpx 20rpx;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.record-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.record-model { font-size: 30rpx; font-weight: bold; color: #1e293b; }
.record-time { font-size: 22rpx; color: #94a3b8; }

.record-spec {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.spec-text { font-size: 24rpx; color: #64748b; }

/* 四维评分标签行 */
.record-scores {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.score-tag {
  background-color: #f1f5f9;
  border-radius: 8rpx;
  padding: 8rpx 16rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6rpx;
}

/* 维修+进水合并标签略宽 */
.score-tag-repair { gap: 8rpx; }

.score-sep { font-size: 20rpx; color: #cbd5e1; }
.score-label { font-size: 22rpx; color: #64748b; }
.score-val { font-size: 22rpx; font-weight: 600; color: #1e293b; }
.status-good { color: #16a34a; }
.status-bad { color: #dc2626; }

/* 系统估价 */
.sys-price-block {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  background-color: #eff6ff;
  border-radius: 12rpx;
  padding: 18rpx 24rpx;
  margin-bottom: 16rpx;
}

.sys-price-label { font-size: 26rpx; color: #1a56db; font-weight: 600; }
.sys-price-value { font-size: 36rpx; font-weight: bold; color: #1a56db; }

.sale-price-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0 16rpx;
}

.sale-price-label { font-size: 24rpx; color: #64748b; }
.sale-price-value { font-size: 28rpx; font-weight: 600; color: #475569; }

/* 平台参考价 */
.platform-block {
