  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.spec-text {
  font-size: 24rpx;
  color: #64748b;
}

.record-scores {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

