  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 12rpx;
  display: block;
}

.platform-list {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
}

.platform-item {
  flex: 1;
  background-color: #f8fafc;
  border: 1rpx solid #e2e8f0;
  border-radius: 10rpx;
  padding: 14rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.platform-name { font-size: 22rpx; color: #64748b; }
.platform-price { font-size: 28rpx; font-weight: bold; color: #16a34a; }

/* 操作按钮 */
.record-actions {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.btn-outline {
  flex: 1;
  background-color: #fff;
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 18rpx;
