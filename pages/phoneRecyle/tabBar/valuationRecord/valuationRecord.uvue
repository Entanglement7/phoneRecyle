<template>
  <scroll-view scroll-y class="container">
    <view class="page-header">
      <text class="page-title">估值记录</text>
    </view>

    <view class="search-bar">
      <input v-model="searchKeyword" placeholder="搜索机型" class="search-input" />
      <button class="search-btn" @click="search">搜索</button>
    </view>

    <view v-if="filteredRecords.length === 0" class="empty">
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无估值记录</text>
    </view>

    <view v-for="(record, index) in filteredRecords" :key="index" class="record-card">
      <view class="record-header">
        <text class="record-model">{{ record.phoneParams.model }}</text>
        <text class="record-time">{{ formatTime(record.valuationTime) }}</text>
      </view>
      <view class="record-spec">
        <text class="spec-text">{{ record.phoneParams.ram }} / {{ record.phoneParams.storage }}</text>
        <text class="spec-text">使用 {{ record.phoneParams.usageMonths }} 个月</text>
      </view>
      <view class="record-scores">
        <view class="score-tag">
          <text class="score-label">外观</text>
          <text class="score-val">{{ record.appearanceScore }}分</text>
        </view>
        <view class="score-tag">
          <text class="score-label">电池</text>
          <text class="score-val">{{ record.functionStatus.batteryHealth }}%</text>
        </view>
      </view>
      <view class="record-prices">
        <view class="price-item">
          <text class="price-label">回收估值</text>
          <text class="price-value recycle">¥{{ record.recyclePrice }}</text>
        </view>
        <view class="price-divider" />
        <view class="price-item">
          <text class="price-label">销售估值</text>
          <text class="price-value sale">¥{{ record.salePrice }}</text>
        </view>
      </view>
      <view class="record-actions">
        <button class="btn-outline" @click="viewDetail(record)">查看详情</button>
        <button class="btn-primary" @click="revaluate(record)">再次评估</button>
      </view>
    </view>
  </scroll-view>
</template>

<script setup>
import { ref, computed, onMounted } from 'vue';

const searchKeyword = ref('');
const records = ref([]);

onMounted(() => {
  const history = uni.getStorageSync('valuationHistory') || [];
  records.value = history.length > 0 ? history : [
    {
      phoneParams: { model: '华为 Mate 60 Pro', ram: '8GB', storage: '256GB', usageMonths: '6' },
      appearanceScore: 90,
      functionStatus: { batteryHealth: '95' },
      recyclePrice: 4899,
      salePrice: 5399,
      valuationTime: new Date().toISOString()
    },
    {
      phoneParams: { model: '华为 P60 Pro', ram: '8GB', storage: '256GB', usageMonths: '12' },
      appearanceScore: 85,
      functionStatus: { batteryHealth: '90' },
      recyclePrice: 3699,
      salePrice: 4099,
      valuationTime: new Date(Date.now() - 30 * 24 * 60 * 60 * 1000).toISOString()
    }
  ];
});

const filteredRecords = computed(() => {
  if (!searchKeyword.value) return records.value;
  return records.value.filter(r => r.phoneParams.model.includes(searchKeyword.value));
});

const formatTime = (t) => {
  const d = new Date(t);
  return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
};

const search = () => {};

const viewDetail = () => {
  uni.showToast({ title: '详情页面开发中', icon: 'none' });
};

const revaluate = (record) => {
  uni.setStorageSync('phoneParams', record.phoneParams);
  uni.navigateTo({ url: '/pages/phoneRecyle/inputParams/inputParams' });
};
</script>

