  margin-bottom: 28rpx;
}

.avatar-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #e2e8f0;
  overflow: hidden;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-preview-img {
  width: 120rpx;
  height: 120rpx;
}

.avatar-preview-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #94a3b8;
}

.avatar-picker-hint {
  font-size: 22rpx;
  color: #1a56db;
}

.modal-field { margin-bottom: 24rpx; }
.modal-label { font-size: 24rpx; color: #64748b; margin-bottom: 10rpx; display: block; }

.modal-input-box {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #f8fafc;
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  height: 80rpx;
}

.modal-input {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: #1e293b;
