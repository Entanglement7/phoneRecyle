  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx 0;
}

.menu-icon { font-size: 34rpx; margin-right: 20rpx; width: 44rpx; text-align: center; }
.menu-text { flex: 1; font-size: 28rpx; color: #1e293b; }
.menu-right { display: flex; flex-direction: row; align-items: center; gap: 8rpx; }
.menu-tag { font-size: 24rpx; color: #94a3b8; }
.menu-arrow { font-size: 36rpx; color: #cbd5e1; }
.divider { height: 1rpx; background-color: #f1f5f9; }

