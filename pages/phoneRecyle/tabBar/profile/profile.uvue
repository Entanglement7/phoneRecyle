  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
}

.card {
  background-color: #fff;
  margin: 20rpx 24rpx 0;
  padding: 0 28rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.card-title {
  font-size: 24rpx;
  font-weight: bold;
  color: #94a3b8;
  padding: 20rpx 0 10rpx;
  display: block;
}

