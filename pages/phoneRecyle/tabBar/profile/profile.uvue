.logout-btn {
  width: 100%;
  background-color: #fff;
  border: 1rpx solid #fca5a5;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #ef4444;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0,0,0,0.5);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  z-index: 999;
  padding: 0 40rpx;
}

.modal-panel {
  background-color: #fff;
