<template>
  <scroll-view scroll-y class="container">
    <!-- 头部 -->
    <view class="profile-header">
      <view class="avatar-wrap" @click="showEditProfile = true">
        <image v-if="userInfo.avatar" :src="userInfo.avatar" class="avatar-img" mode="aspectFill" />
        <text v-else class="avatar-text">{{ displayInitial }}</text>
        <view class="avatar-edit-badge"><text class="avatar-edit-icon">✎</text></view>
      </view>
      <view class="user-meta">
        <text class="user-name">{{ userInfo.nickname || userInfo.username || '用户' }}</text>
        <text class="user-id">账号：{{ userInfo.username }}</text>
      </view>
    </view>

    <!-- 我的服务 -->
    <view class="card">
      <text class="card-title">我的服务</text>
      <view class="menu-item" @click="viewValuationHistory">
        <text class="menu-icon">📱</text>
        <text class="menu-text">估值历史</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <!-- 账户设置 -->
    <view class="card">
      <text class="card-title">账户设置</text>
      <view class="menu-item" @click="showEditProfile = true">
        <text class="menu-icon">👤</text>
        <text class="menu-text">编辑个人资料</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="divider" />
      <view class="menu-item" @click="showChangePwd = true">
        <text class="menu-icon">🔒</text>
        <text class="menu-text">修改密码</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="divider" />
      <view class="menu-item" @click="showBindPhone = true">
        <text class="menu-icon">📞</text>
        <text class="menu-text">绑定手机</text>
        <view class="menu-right">
          <text class="menu-tag">{{ userInfo.phone || '未绑定' }}</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>

    <view class="logout-wrap">
      <button class="logout-btn" @click="logout">退出登录</button>
    </view>

    <!-- 编辑个人资料弹窗 -->
    <view v-if="showEditProfile" class="modal-mask" @click.self="closeEditProfile">
      <view class="modal-panel">
        <text class="modal-title">编辑个人资料</text>

        <!-- 头像选择 -->
        <view class="avatar-picker" @click="pickAvatar">
          <view class="avatar-preview">
            <image v-if="editForm.avatar" :src="editForm.avatar" class="avatar-preview-img" mode="aspectFill" />
            <text v-else class="avatar-preview-text">{{ displayInitial }}</text>
          </view>
          <text class="avatar-picker-hint">点击更换头像</text>
        </view>

        <view class="modal-field">
          <text class="modal-label">昵称</text>
          <view class="modal-input-box">
            <input v-model="editForm.nickname" placeholder="请输入昵称" placeholder-style="color:#94a3b8;" class="modal-input" maxlength="20" />
          </view>
        </view>

        <view class="modal-actions">
          <button class="modal-btn-cancel" @click="closeEditProfile">取消</button>
          <button class="modal-btn-confirm" :disabled="profileLoading" @click="submitEditProfile">
            {{ profileLoading ? '保存中...' : '保存' }}
          </button>
        </view>
      </view>
    </view>

    <!-- 修改密码弹窗 -->
    <view v-if="showChangePwd" class="modal-mask" @click.self="closePwd">
      <view class="modal-panel">
        <text class="modal-title">修改密码</text>
        <view class="modal-field">
          <text class="modal-label">原密码</text>
          <view class="modal-input-box">
            <input v-model="pwd.old" type="password" placeholder="请输入原密码" placeholder-style="color:#94a3b8;" class="modal-input" />
          </view>
        </view>
        <view class="modal-field">
          <text class="modal-label">新密码</text>
          <view class="modal-input-box">
            <input v-model="pwd.new1" type="password" placeholder="至少6位" placeholder-style="color:#94a3b8;" class="modal-input" />
          </view>
        </view>
        <view class="modal-field">
          <text class="modal-label">确认新密码</text>
          <view class="modal-input-box">
            <input v-model="pwd.new2" type="password" placeholder="再次输入新密码" placeholder-style="color:#94a3b8;" class="modal-input" />
          </view>
        </view>
        <view class="modal-actions">
          <button class="modal-btn-cancel" @click="closePwd">取消</button>
          <button class="modal-btn-confirm" :disabled="pwdLoading" @click="submitChangePwd">
            {{ pwdLoading ? '提交中...' : '确认修改' }}
          </button>
        </view>
      </view>
    </view>

    <!-- 绑定手机弹窗 -->
    <view v-if="showBindPhone" class="modal-mask" @click.self="closePhone">
      <view class="modal-panel">
        <text class="modal-title">绑定手机号</text>
        <view class="modal-field">
          <text class="modal-label">手机号</text>
          <view class="modal-input-box">
            <input v-model="phoneNum" type="number" placeholder="请输入手机号" placeholder-style="color:#94a3b8;" class="modal-input" maxlength="11" />
          </view>
        </view>
        <view class="modal-actions">
          <button class="modal-btn-cancel" @click="closePhone">取消</button>
          <button class="modal-btn-confirm" @click="submitBindPhone">确认绑定</button>
        </view>
      </view>
    </view>
  </scroll-view>
</template>

<script setup>
import { ref, computed, onMounted } from 'vue';
import { api, clearToken, getToken } from '@/common/api.uts';

const userInfo = ref({ username: '', nickname: '', avatar: '', phone: '' });

const displayInitial = computed(() => {
  const name = userInfo.value.nickname || userInfo.value.username || '用';
  return name[0].toUpperCase();
});

onMounted(async () => {
  const token = getToken();
  if (!token) {
    uni.reLaunch({ url: '/pages/phoneRecyle/login/login' });
    return;
  }

  const stored = uni.getStorageSync('userInfo');
  if (stored) userInfo.value = { ...userInfo.value, ...stored };
  try {
    const me = await api.me();
    userInfo.value = { ...userInfo.value, ...me };
    uni.setStorageSync('userInfo', userInfo.value);
  } catch {}
});

const viewValuationHistory = () => {
  uni.switchTab({ url: '/pages/phoneRecyle/tabBar/valuationRecord/valuationRecord' });
};

// 编辑个人资料
const showEditProfile = ref(false);
const profileLoading = ref(false);
const editForm = ref({ nickname: '', avatar: '' });

const openEditProfile = () => {
  editForm.value = { nickname: userInfo.value.nickname || '', avatar: userInfo.value.avatar || '' };
  showEditProfile.value = true;
};

const closeEditProfile = () => {
  showEditProfile.value = false;
};

const pickAvatar = () => {
  uni.chooseImage({
    count: 1,
    sizeType: ['compressed'],
    sourceType: ['album', 'camera'],
    success: (res) => {
      const path = res.tempFilePaths[0];
      uni.getFileSystemManager().readFile({
        filePath: path,
        encoding: 'base64',
        success: (r) => {
          editForm.value.avatar = 'data:image/jpeg;base64,' + r.data;
        },
        fail: () => {
          editForm.value.avatar = path;
        }
      });
    }
  });
};

const submitEditProfile = async () => {
  profileLoading.value = true;
  try {
    await api.updateProfile({
      nickname: editForm.value.nickname,
      avatar:   editForm.value.avatar,
      phone:    userInfo.value.phone || '',
    });
    userInfo.value = { ...userInfo.value, nickname: editForm.value.nickname, avatar: editForm.value.avatar };
    uni.setStorageSync('userInfo', userInfo.value);
    uni.showToast({ title: '保存成功', icon: 'success' });
    closeEditProfile();
  } finally {
    profileLoading.value = false;
  }
};

// 修改密码
const showChangePwd = ref(false);
const pwdLoading = ref(false);
const pwd = ref({ old: '', new1: '', new2: '' });

const closePwd = () => {
  showChangePwd.value = false;
  pwd.value = { old: '', new1: '', new2: '' };
};

const submitChangePwd = async () => {
  if (!pwd.value.old) { uni.showToast({ title: '请输入原密码', icon: 'none' }); return; }
  if (pwd.value.new1.length < 6) { uni.showToast({ title: '新密码不能少于6位', icon: 'none' }); return; }
  if (pwd.value.new1 !== pwd.value.new2) { uni.showToast({ title: '两次密码不一致', icon: 'none' }); return; }
  pwdLoading.value = true;
  try {
    await api.changePassword(pwd.value.old, pwd.value.new1);
    uni.showToast({ title: '密码修改成功', icon: 'success' });
    closePwd();
  } finally {
    pwdLoading.value = false;
  }
};

// 绑定手机
const showBindPhone = ref(false);
const phoneNum = ref('');

const closePhone = () => { showBindPhone.value = false; phoneNum.value = ''; };

const submitBindPhone = async () => {
  if (!/^1[3-9]\d{9}$/.test(phoneNum.value)) {
    uni.showToast({ title: '请输入正确的手机号', icon: 'none' }); return;
  }
  try {
    await api.updateProfile({
      nickname: userInfo.value.nickname || '',
      avatar:   userInfo.value.avatar || '',
      phone:    phoneNum.value,
    });
    userInfo.value = { ...userInfo.value, phone: phoneNum.value };
    uni.setStorageSync('userInfo', userInfo.value);
    uni.showToast({ title: '绑定成功', icon: 'success' });
    closePhone();
  } catch {}
};

// 退出登录
const logout = () => {
  uni.showModal({
    title: '确认退出',
    content: '确定要退出登录吗？',
    success: (res) => {
      if (res.confirm) {
        clearToken();
        uni.reLaunch({ url: '/pages/phoneRecyle/login/login' });
      }
    }
  });
};
</script>

<style scoped>
.container {
  background-color: #f5f6fa;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.profile-header {
  background-color: #1a56db;
  padding: 50rpx 30rpx 40rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.avatar-wrap {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.avatar-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.5);
}

