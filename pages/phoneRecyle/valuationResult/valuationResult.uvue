  background-color: #fff7ed;
}

.score-tag-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #059669;
}

.score-tag-warn .score-tag-text {
  color: #d97706;
}

.action-row {
  display: flex;
  gap: 20rpx;
  padding: 30rpx 24rpx 40rpx;
}

.btn-primary {
