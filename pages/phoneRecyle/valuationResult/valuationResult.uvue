  font-size: 28rpx;
  color: #1e293b;
  font-weight: 600;
}

.card {
  background-color: #fff;
  margin: 24rpx 24rpx 0;
  padding: 28rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.07);
}

.card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1e293b;
  margin-bottom: 20rpx;
  display: block;
}

.divider {
  height: 1rpx;
  background-color: #f1f5f9;
  margin: 4rpx 0;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  font-size: 28rpx;
}

.info-label {
  color: #64748b;
}

.info-value {
  color: #1e293b;
  font-weight: 500;
}

.score-tag {
  background-color: #ecfdf5;
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
}

