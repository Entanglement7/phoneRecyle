  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
}

.price-main {
  font-size: 80rpx;
  font-weight: bold;
  color: #fbbf24;
  letter-spacing: -2rpx;
}

.platform-tip {
  font-size: 22rpx;
  color: #94a3b8;
  margin-bottom: 20rpx;
  display: block;
}

.platform-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.platform-row:last-child {
  border-bottom: none;
}

