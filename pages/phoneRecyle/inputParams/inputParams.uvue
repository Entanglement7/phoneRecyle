<template>
  <view class="container">
    <view class="page-header">
      <text class="page-title">手机基础参数录入</text>
      <text class="page-desc">请填写手机的基本配置信息</text>
    </view>

    <view class="form">
      <!-- 华为机型 -->
      <view class="form-item">
        <text class="label">华为机型</text>
        <view class="select-box" @click="openDropdown('model')">
          <text class="select-value">{{ selectedModel || '请选择机型' }}</text>
          <text class="select-arrow">⌄</text>
        </view>
      </view>
      <view class="divider" />

      <!-- 内存 -->
      <view class="form-item">
        <text class="label">内存</text>
        <view class="select-box" @click="openDropdown('ram')">
          <text class="select-value">{{ selectedRam || '请选择内存' }}</text>
          <text class="select-arrow">⌄</text>
        </view>
      </view>
      <view class="divider" />

      <!-- 存储 -->
      <view class="form-item">
        <text class="label">存储</text>
        <view class="select-box" @click="openDropdown('storage')">
          <text class="select-value">{{ selectedStorage || '请选择存储' }}</text>
          <text class="select-arrow">⌄</text>
        </view>
      </view>
      <view class="divider" />

      <!-- 购买渠道 -->
      <view class="form-item">
        <text class="label">购买渠道</text>
        <view class="select-box" @click="openDropdown('channel')">
          <text class="select-value">{{ selectedChannel || '请选择渠道' }}</text>
          <text class="select-arrow">⌄</text>
        </view>
      </view>
      <view class="divider" />

      <!-- 使用时长 -->
      <view class="form-item">
        <text class="label">使用时长（月）</text>
        <input type="number" v-model="usageMonths" placeholder="请输入使用时长" class="input" />
      </view>

      <button type="primary" class="submit-btn" @click="submitParams">下一步：外观检测</button>
    </view>

    <!-- 下拉选择器弹窗 -->
    <view v-if="dropdownVisible" class="dropdown-mask" @click="closeDropdown">
      <view class="dropdown-panel" @click.stop="">
        <view class="dropdown-header">
          <text class="dropdown-title">{{ dropdownTitle }}</text>
          <text class="dropdown-close" @click="closeDropdown">✕</text>
        </view>
        <view class="search-wrap">
          <text class="search-icon">🔍</text>
          <input
            class="search-input"
            v-model="searchKeyword"
            :placeholder="'搜索' + dropdownTitle"
            focus
          />
          <text v-if="searchKeyword" class="search-clear" @click="searchKeyword = ''">✕</text>
        </view>
        <scroll-view scroll-y class="option-list">
          <view
            v-for="(item, index) in filteredOptions"
            :key="index"
            class="option-item"
            :class="{ 'option-active': item === currentValue }"
            @click="selectOption(item)"
          >
            <text class="option-text">{{ item }}</text>
            <text v-if="item === currentValue" class="option-check">✓</text>
          </view>
          <view v-if="filteredOptions.length === 0" class="option-empty">
            <text class="option-empty-text">无匹配结果</text>
          </view>
        </scroll-view>
      </view>
    </view>
  </view>
</template>

<script setup>
import { ref, computed } from 'vue';

const models = ['华为 Mate 60 Pro', '华为 Mate 60', '华为 P60 Pro', '华为 P60', '华为 Mate 50 Pro', '华为 Mate 50', '华为 P50 Pro', '华为 P50', '华为 nova 11 Pro', '华为 nova 11'];
const ramOptions = ['4GB', '6GB', '8GB', '12GB', '16GB'];
const storageOptions = ['64GB', '128GB', '256GB', '512GB', '1TB'];
const channelOptions = ['官方渠道', '授权店', '二手市场', '其他'];

const selectedModel = ref('华为 Mate 60 Pro');
const selectedRam = ref('8GB');
const selectedStorage = ref('256GB');
const selectedChannel = ref('官方渠道');
const usageMonths = ref('');

// 下拉状态
const dropdownVisible = ref(false);
const dropdownType = ref('');
const dropdownTitle = ref('');
const searchKeyword = ref('');
const currentOptions = ref([]);
const currentValue = ref('');

const filteredOptions = computed(() => {
  if (!searchKeyword.value) return currentOptions.value;
  const kw = searchKeyword.value.toLowerCase();
  return currentOptions.value.filter(item => item.toLowerCase().includes(kw));
});

const openDropdown = (type) => {
  dropdownType.value = type;
  searchKeyword.value = '';
  if (type === 'model') {
    dropdownTitle.value = '华为机型';
    currentOptions.value = models;
    currentValue.value = selectedModel.value;
  } else if (type === 'ram') {
    dropdownTitle.value = '内存';
    currentOptions.value = ramOptions;
    currentValue.value = selectedRam.value;
  } else if (type === 'storage') {
    dropdownTitle.value = '存储';
    currentOptions.value = storageOptions;
    currentValue.value = selectedStorage.value;
  } else if (type === 'channel') {
    dropdownTitle.value = '购买渠道';
    currentOptions.value = channelOptions;
    currentValue.value = selectedChannel.value;
  }
  dropdownVisible.value = true;
};

const selectOption = (item) => {
  if (dropdownType.value === 'model') selectedModel.value = item;
  else if (dropdownType.value === 'ram') selectedRam.value = item;
  else if (dropdownType.value === 'storage') selectedStorage.value = item;
  else if (dropdownType.value === 'channel') selectedChannel.value = item;
  closeDropdown();
};

const closeDropdown = () => {
  dropdownVisible.value = false;
  searchKeyword.value = '';
};

const submitParams = () => {
  if (!usageMonths.value) {
    uni.showToast({ title: '请输入使用时长', icon: 'none' });
    return;
  }
  const params = {
    model: selectedModel.value,
    ram: selectedRam.value,
    storage: selectedStorage.value,
    channel: selectedChannel.value,
    usageMonths: usageMonths.value
  };
  uni.setStorageSync('phoneParams', params);
  uni.showToast({ title: '参数提交成功', icon: 'success' });
  setTimeout(() => {
    uni.navigateTo({ url: '/pages/phoneRecyle/appearanceDetect/appearanceDetect' });
  }, 1000);
};
</script>

